OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-latest

PINECONE_API_KEY=
PINECONE_INDEX=local-rag-multimodal
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=3072
PINECONE_METRIC=cosine
SYNC_INDEX_ON_INGEST=true
PINECONE_DELETE_BATCH_SIZE=100

CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=8
MAX_CONTEXT_ITEMS=10
MAX_IMAGES_IN_RESPONSE=3
MAX_TABLES_IN_RESPONSE=1
MAX_IMAGES_IN_CONTEXT=1
ENABLE_IMAGE_CAPTIONING=true
IMAGE_CAPTION_MAX_IMAGES=300
IMAGE_CAPTION_MAX_CHARS=180
IMAGE_CAPTION_WORKERS=4
RETRIEVE_TEXT_K=10
RETRIEVE_TABLE_K=6
RETRIEVE_IMAGE_K=6
RETRIEVE_WEIGHT_TEXT=1.0
RETRIEVE_WEIGHT_TABLE=0.6
RETRIEVE_WEIGHT_IMAGE=0.45
RETRIEVE_RRF_K=50
RETRIEVE_MIN_FUSED_SCORE=0.010
RETRIEVE_MIN_QUERY_OVERLAP=0.03
RETRIEVE_RERANK_OVERLAP_WEIGHT=0.35
RETRIEVE_RERANK_VECTOR_WEIGHT=0.65
RETRIEVE_RERANK_SOURCE_WEIGHT=0.20
RETRIEVE_ENABLE_QUERY_SOURCE_ROUTING=true
RETRIEVE_DOMAIN_MIN_ITEMS=3
RETRIEVE_MIN_TEXT_CHARS=120
RETRIEVE_MIN_INFORMATIVE_TOKENS=8
RETRIEVE_MAX_HEADING_TOKEN_RATIO=0.70
RETRIEVE_DROP_TABLE_STUBS=true
RETRIEVE_MODALITY_BONUS_TEXT=0.08
RETRIEVE_MODALITY_BONUS_TABLE=0.0
MIN_TEXT_CONTEXT_ITEMS=2
MAX_CONTEXT_CHARS=9000
ANSWER_MAX_TOKENS=700
ANSWER_TEMPERATURE=0.0
REQUIRE_CITATIONS_PER_ANSWER=true
DATA_DIR=data
PROCESSED_DIR=data/processed
